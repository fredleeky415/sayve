#
# Sayve unified environment template
# Copy to .env.local for local development, or split into deploy env vars.
#

# App mode
SAYVE_ENV_TARGET=private-beta
MEMORY_REPOSITORY=supabase

# Browser / app origin
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<paste-browser-anon-key>
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<paste-service-role-key>
SUPABASE_DEFAULT_HOUSEHOLD_ID=<founder-household-uuid>
SUPABASE_AUTH_REQUIRED=1
SUPABASE_MEDIA_BUCKET=<private-media-bucket>

# Private beta access
APP_ACCESS_TOKEN=<generate-strong-access-token>
ADMIN_CONSOLE_TOKEN=<generate-strong-admin-token>

# OpenAI
OPENAI_API_KEY=<paste-openai-api-key>
OPENAI_CAPTURE_MODEL=gpt-5.4-mini
OPENAI_CAPTURE_MAX_OUTPUT_TOKENS=220
OPENAI_CONVERSATION_MODEL=gpt-5.4-mini
OPENAI_CONVERSATION_MAX_OUTPUT_TOKENS=120
OPENAI_ESCALATION_MODEL=gpt-5.5
OPENAI_RECEIPT_VISION_MODEL=gpt-5.4-mini
OPENAI_SPEECH_TO_TEXT_MODEL=gpt-4o-mini-transcribe

# AI media / upload guardrails
AUDIO_TRANSCRIPTION_MAX_BYTES=25000000
RECEIPT_VISION_MAX_BYTES=8000000
RECEIPT_UPLOAD_MAX_BYTES=10000000
VOICE_UPLOAD_MAX_BYTES=25000000

# Founder cost analytics
OPENAI_CAPTURE_INPUT_USD_PER_1M=0
OPENAI_CAPTURE_OUTPUT_USD_PER_1M=0
OPENAI_RECEIPT_VISION_INPUT_USD_PER_1M=0
OPENAI_RECEIPT_VISION_OUTPUT_USD_PER_1M=0
OPENAI_CONVERSATION_INPUT_USD_PER_1M=0
OPENAI_CONVERSATION_OUTPUT_USD_PER_1M=0
OPENAI_STT_INPUT_USD_PER_1M=0
OPENAI_STT_OUTPUT_USD_PER_1M=0

# Deploy smoke
SAYVE_DEPLOY_URL=https://your-domain.com
SAYVE_DEPLOYMENT_SMOKE_VERIFIED=0
SAYVE_DEPLOYMENT_SMOKE_VERIFIED_AT=<iso-after-smoke>
SAYVE_DEPLOYMENT_SMOKE_TARGET=https://your-domain.com
SAYVE_REQUIRE_MEDIA_STORAGE=0
SAYVE_REQUIRE_AUTH_SMOKE=1
SAYVE_REQUIRE_TWO_MEMBER_SMOKE=1
SAYVE_REQUIRE_VIEWER_SMOKE=1
SAYVE_REQUIRE_INVITE_SMOKE=1
SAYVE_REQUIRE_BOOTSTRAP_SMOKE=1
SAYVE_REQUIRE_OPENAI_SMOKE=1
SAYVE_REQUIRE_PRIVACY_SMOKE=1
SAYVE_TEST_SUPABASE_ACCESS_TOKEN=<owner-session-token>
SAYVE_TEST_SECOND_SUPABASE_ACCESS_TOKEN=<member-session-token>
SAYVE_TEST_VIEWER_SUPABASE_ACCESS_TOKEN=<viewer-session-token>
SAYVE_TEST_INVITE_ACCEPT_SUPABASE_ACCESS_TOKEN=<fresh-unjoined-session-token>
SAYVE_TEST_BOOTSTRAP_SUPABASE_ACCESS_TOKEN=<fresh-no-household-session-token>
