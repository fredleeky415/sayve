# Sayve private beta deployment example
SAYVE_ENV_TARGET=private-beta
MEMORY_REPOSITORY=supabase
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<paste-browser-anon-key>
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<paste-service-role-key>
SUPABASE_DEFAULT_HOUSEHOLD_ID=<founder-household-uuid>
SUPABASE_AUTH_REQUIRED=1
APP_ACCESS_TOKEN=<generate-strong-access-token>
ADMIN_CONSOLE_TOKEN=<generate-strong-admin-token>
SUPABASE_MEDIA_BUCKET=<set-before-public-launch>
RECEIPT_UPLOAD_MAX_BYTES=<set-before-public-launch>
VOICE_UPLOAD_MAX_BYTES=<set-before-public-launch>
